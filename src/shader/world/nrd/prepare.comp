#version 460
#extension GL_GOOGLE_include_directive : require

#define NRD_GLSL 1
#include "../../../extern/nrd/Shaders/Include/NRD.hlsli"
#include "common/shared.hpp"

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, rgba16f) uniform readonly image2D directRadianceImage;
layout(set = 0, binding = 1, rgba16f) uniform readonly image2D diffuseIndirectRadianceImage;
layout(set = 0, binding = 2, rgba16f) uniform readonly image2D specularIndirectRadianceImage;
layout(set = 0, binding = 3, rgba8) uniform readonly image2D diffuseAlbedoMetallicImage;
layout(set = 0, binding = 4, rgba8) uniform readonly image2D specularAlbedoImage;
layout(set = 0, binding = 5, rg16f) uniform readonly image2D motionVectorImage;
layout(set = 0, binding = 6, rgba16f) uniform readonly image2D normalRoughnessImage;
layout(set = 0, binding = 7, r16f) uniform readonly image2D linearDepthImage;
layout(set = 0, binding = 8, rgba16f) uniform readonly image2D clearRadianceImage;
layout(set = 0, binding = 9, r16f) uniform readonly image2D diffuseHitDepthImage;
layout(set = 0, binding = 10, r16f) uniform readonly image2D specularHitDepthImage;
layout(set = 0, binding = 11, rgba16f) uniform readonly image2D refractionRadianceImage;

layout(set = 1, binding = 0, rgba16f) uniform writeonly image2D nrdDiffuseRadianceImage;
layout(set = 1, binding = 1, rgba16f) uniform writeonly image2D nrdSpecularRadianceImage;
layout(set = 1, binding = 2, rg16f) uniform writeonly image2D nrdMotionVectorImage;
#if NRD_NORMAL_ENCODING == NRD_NORMAL_ENCODING_R10G10B10A2_UNORM
layout(set = 1, binding = 3, rgb10_a2) uniform writeonly image2D nrdNormalRoughnessImage;
#elif NRD_NORMAL_ENCODING == NRD_NORMAL_ENCODING_RGBA8_UNORM
layout(set = 1, binding = 3, rgba8) uniform writeonly image2D nrdNormalRoughnessImage;
#elif NRD_NORMAL_ENCODING == NRD_NORMAL_ENCODING_RGBA8_SNORM
layout(set = 1, binding = 3, rgba8_snorm) uniform writeonly image2D nrdNormalRoughnessImage;
#elif NRD_NORMAL_ENCODING == NRD_NORMAL_ENCODING_RGBA16_UNORM
layout(set = 1, binding = 3, rgba16) uniform writeonly image2D nrdNormalRoughnessImage;
#elif NRD_NORMAL_ENCODING == NRD_NORMAL_ENCODING_RGBA16_SNORM
layout(set = 1, binding = 3, rgba16_snorm) uniform writeonly image2D nrdNormalRoughnessImage;
#else
#error Unsupported NRD normal encoding
#endif
layout(set = 1, binding = 4, r16f) uniform writeonly image2D nrdLinearDepthImage;

layout(set = 2, binding = 0) uniform WorldUniform {
    WorldUBO worldUBO;
};

const vec4 gDiffHitDistParams = vec4(3.0, 0.1, 20.0, -25.0);
const vec4 gSpecHitDistParams = vec4(3.0, 0.1, 20.0, -25.0);
const float NRD_INF_DEPTH = 65504.0;

vec3 safeDiv(vec3 a, vec3 b) {
    return a / max(b, vec3(1e-3));
}

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(directRadianceImage);
    if (pixel.x >= size.x || pixel.y >= size.y) return;

    float linearDepth = imageLoad(linearDepthImage, pixel).r;
    bool invalidDepth = isnan(linearDepth) || isinf(linearDepth) || linearDepth >= NRD_INF_DEPTH * 0.9;
    bool needDenoise = imageLoad(clearRadianceImage, pixel).a == 0.0 && !invalidDepth;
    if (!needDenoise) {
        imageStore(nrdDiffuseRadianceImage, pixel, vec4(0.0));
        imageStore(nrdSpecularRadianceImage, pixel, vec4(0.0));
        imageStore(nrdMotionVectorImage, pixel, vec4(0.0));
        imageStore(nrdNormalRoughnessImage, pixel, vec4(0.0, 1.0, 0.0, 1.0));
        imageStore(nrdLinearDepthImage, pixel, vec4(min(linearDepth, NRD_INF_DEPTH), 0.0, 0.0, 0.0));
        return;
    }

    imageStore(nrdLinearDepthImage, pixel, vec4(linearDepth, 0.0, 0.0, 0.0));

    vec2 nrdMV = imageLoad(motionVectorImage, pixel).xy;
    nrdMV += worldUBO.cameraJitter;
    if (any(isnan(nrdMV)) || any(isinf(nrdMV))) nrdMV = vec2(0.0);
    imageStore(nrdMotionVectorImage, pixel, vec4(nrdMV, 0.0, 0.0));

    vec4 normalRoughness = imageLoad(normalRoughnessImage, pixel);
    vec3 normal = normalize(normalRoughness.xyz + vec3(0.0, 1e-6, 0.0));
    float roughness = normalRoughness.w;
    imageStore(nrdNormalRoughnessImage, pixel, NRD_FrontEnd_PackNormalAndRoughness(normal, roughness, 0.0));

    vec3 diffRadiance = imageLoad(diffuseIndirectRadianceImage, pixel).rgb + imageLoad(directRadianceImage, pixel).rgb;
    float diffHitDist = max(imageLoad(diffuseHitDepthImage, pixel).r, 0.001);
    vec3 diffAlbedo = max(imageLoad(diffuseAlbedoMetallicImage, pixel).rgb, vec3(0.05));
    vec3 demodDiffuse = safeDiv(diffRadiance, diffAlbedo);
    float normDiffHitDist = REBLUR_FrontEnd_GetNormHitDist(diffHitDist, linearDepth, gDiffHitDistParams, 1.0);
    imageStore(nrdDiffuseRadianceImage, pixel,
               REBLUR_FrontEnd_PackRadianceAndNormHitDist(demodDiffuse, normDiffHitDist, true));

    vec3 specRadiance = imageLoad(specularIndirectRadianceImage, pixel).rgb;
    float specHitDist = imageLoad(specularHitDepthImage, pixel).r;
    specHitDist = NRD_FrontEnd_TrimHitDistance(specHitDist, 1e-3);
    vec3 specAlbedo = max(imageLoad(specularAlbedoImage, pixel).rgb, vec3(0.04));
    vec3 demodSpecular = safeDiv(specRadiance, specAlbedo);
    float normSpecHitDist = REBLUR_FrontEnd_GetNormHitDist(specHitDist, linearDepth, gSpecHitDistParams, roughness);
    imageStore(nrdSpecularRadianceImage, pixel,
               REBLUR_FrontEnd_PackRadianceAndNormHitDist(demodSpecular, normSpecHitDist, true));
}
