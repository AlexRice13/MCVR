#version 460
#extension GL_GOOGLE_include_directive : require

#define NRD_GLSL 1
#include "../../../extern/nrd/Shaders/Include/NRD.hlsli"
#include "common/shared.hpp"

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, rgba8) uniform readonly image2D diffuseAlbedoMetallicImage;
layout(set = 0, binding = 1, rgba8) uniform readonly image2D specularAlbedoImage;
layout(set = 0, binding = 2, rgba16f) uniform readonly image2D normalRoughnessImage;
layout(set = 0, binding = 3, r16f) uniform readonly image2D linearDepthImage;
layout(set = 0, binding = 4, rgba16f) uniform readonly image2D clearRadianceImage;
layout(set = 0, binding = 5, rgba16f) uniform readonly image2D baseEmissionImage;
layout(set = 0, binding = 6, rgba16f) uniform readonly image2D refractionRadianceImage;
layout(set = 0, binding = 7, rg16f) uniform readonly image2D motionVectorImage;
layout(set = 0, binding = 8, rgba16f) uniform readonly image2D fogImage;

layout(set = 1, binding = 0, rgba16f) uniform readonly image2D denoisedDiffuseRadianceImage;
layout(set = 1, binding = 1, rgba16f) uniform readonly image2D denoisedSpecularRadianceImage;
layout(set = 1, binding = 2, rgba16f) uniform writeonly image2D denoisedRadianceImage;
layout(set = 1, binding = 3, rgba16f) uniform readonly image2D refractionHistoryRadianceImagePrev;
layout(set = 1, binding = 4, r16f) uniform readonly image2D refractionHistoryDepthImagePrev;
layout(set = 1, binding = 5, rgba16f) uniform writeonly image2D refractionHistoryRadianceImage;
layout(set = 1, binding = 6, r16f) uniform writeonly image2D refractionHistoryDepthImage;

layout(set = 2, binding = 0) uniform WorldUniform {
    WorldUBO worldUBO;
};
layout(set = 2, binding = 1) uniform SkyUniform {
    SkyUBO skyUBO;
};

const float kInfDepth = 65504.0;
const float kMinDiffuseAlbedo = 0.05;
const float kMinSpecularAlbedo = 0.04;
const vec3 kUnderwaterColor = vec3(0.0, 0.48, 0.65);

vec3 remodulateDiffuse(vec3 radiance, vec3 albedo) {
    return radiance * max(albedo, vec3(kMinDiffuseAlbedo));
}

vec3 remodulateSpecular(vec3 radiance, vec3 albedo) {
    return radiance * max(albedo, vec3(kMinSpecularAlbedo));
}

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(denoisedRadianceImage);
    if (pixel.x >= size.x || pixel.y >= size.y) return;

    vec4 diffData = imageLoad(denoisedDiffuseRadianceImage, pixel);
    vec4 specData = imageLoad(denoisedSpecularRadianceImage, pixel);
    vec3 diffRadiance = REBLUR_BackEnd_UnpackRadianceAndNormHitDist(diffData).rgb;
    vec3 specRadiance = REBLUR_BackEnd_UnpackRadianceAndNormHitDist(specData).rgb;

    vec3 diffAlbedo = imageLoad(diffuseAlbedoMetallicImage, pixel).rgb;
    vec3 specAlbedo = imageLoad(specularAlbedoImage, pixel).rgb;
    diffRadiance = remodulateDiffuse(diffRadiance, diffAlbedo);
    specRadiance = remodulateSpecular(specRadiance, specAlbedo);

    vec4 clear = imageLoad(clearRadianceImage, pixel);
    vec3 clearRadiance = clear.rgb * clear.a;
    vec4 emission = imageLoad(baseEmissionImage, pixel);
    vec3 emissionRadiance = emission.rgb * emission.a;
    vec4 fogData = imageLoad(fogImage, pixel);
    bool useFogCompose = fogData.a >= 0.0;
    float fogTransmittance = useFogCompose ? clamp(fogData.a, 0.0, 1.0) : 1.0;
    vec3 fogAdditive = useFogCompose ? fogData.rgb : vec3(0.0);

    float currDepth = imageLoad(linearDepthImage, pixel).r;
    bool currDepthValid = !(isnan(currDepth) || isinf(currDepth) || currDepth >= kInfDepth * 0.9);
    vec4 currRefractionData = imageLoad(refractionRadianceImage, pixel);
    bool hasCurrentRefraction = currRefractionData.a > 0.5 && clear.a == 0.0 && currDepthValid;
    vec3 refractionRadiance = hasCurrentRefraction ? max(currRefractionData.rgb, vec3(0.0)) : vec3(0.0);

    // Keep the history surfaces cleared: compose should match the raygen split exactly.
    imageStore(refractionHistoryRadianceImage, pixel, vec4(0.0));
    imageStore(refractionHistoryDepthImage, pixel, vec4(kInfDepth, 0.0, 0.0, 0.0));

    vec3 result;
    if (clear.a > 0.0) {
        result = clearRadiance;
    } else {
        vec3 baseRadiance = diffRadiance + specRadiance + refractionRadiance + emissionRadiance;
        if (useFogCompose && skyUBO.cameraSubmersionType == 1) {
            baseRadiance *= kUnderwaterColor;
        }
        result = baseRadiance * fogTransmittance + fogAdditive;
    }
    imageStore(denoisedRadianceImage, pixel, vec4(max(result, 0.0), 1.0));
}
